body {
  font-family: Arial;
  background: #fff3e0;
  display: flex;
  justify-content: center;
  padding: 20px;
}

.container {
  background: white;
  padding: 20px;
  width: 320px;
  border-radius: 12px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

input, select {
  width: 100%;
  margin: 5px 0 10px;
  padding: 8px;
}

button {
  width: 100%;
  padding: 10px;
  background: #d2691e;
  color: white;
  border: none;
  border-radius: 8px;
}
